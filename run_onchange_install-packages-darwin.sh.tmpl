#!/bin/bash
{{ if eq .chezmoi.os "darwin" -}}
echo "Starting package installation for macOS..."
if command -v brew >/dev/null 2>&1; then
  brew install wezterm zsh starship zoxide fzf eza bat git ripgrep fd jq lazygit btop neovim zsh-autosuggestions zsh-syntax-highlighting || true
else
  echo "Homebrew not found. Please install Homebrew first."
  exit 1
fi
if [ ! -d "$HOME/powerlevel10k" ]; then
  echo "Cloning Powerlevel10k..."
  git clone --depth=1 https://github.com/romkatv/powerlevel10k.git "$HOME/powerlevel10k" 2>/dev/null || true
fi

# Install MesloLGS NF fonts for Powerlevel10k
FONT_DIR="$HOME/Library/Fonts"
mkdir -p "$FONT_DIR"
fonts=(
  "MesloLGS NF Regular.ttf"
  "MesloLGS NF Bold.ttf"
  "MesloLGS NF Italic.ttf"
  "MesloLGS NF Bold Italic.ttf"
)
echo "Installing MesloLGS NF fonts..."
for font in "${fonts[@]}"; do
  if [ ! -f "$FONT_DIR/$font" ]; then
    curl -sL "https://github.com/romkatv/powerlevel10k-media/raw/master/${font// /%20}" -o "$FONT_DIR/$font" || true
  fi
done
{{- end }}
